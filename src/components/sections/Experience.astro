---
import SectionHeading from '~/components/ui/SectionHeading.astro';
import { experience } from '~/data/experience';
---
<section id="experience">
  <div class="container">
    <SectionHeading index="04" label="experience">The <span class="b">path</span>.</SectionHeading>

    <div class="timeline reveal" data-timeline>
      <div class="timeline__prog" data-prog></div>
      {experience.map((e) => (
        <div class="tl-item">
          <span class="when">{e.when}</span>
          <h3>{e.title}</h3>
          <p>{e.body}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .timeline { position: relative; padding-left: var(--space-4); }
  .timeline::before { content: ""; position: absolute; left: 6px; top: 6px; bottom: 6px; width: 2px; background: var(--line); }
  .timeline__prog { position: absolute; left: 6px; top: 6px; width: 2px; background: var(--accent);
    box-shadow: 0 0 12px var(--accent); height: var(--p, 0%); }
  .tl-item { position: relative; padding-bottom: var(--space-4); }
  .tl-item:last-child { padding-bottom: 0; }
  .tl-item::before { content: ""; position: absolute; left: -1.97rem; top: 5px; width: 14px; height: 14px;
    border-radius: 50%; background: var(--bg); border: 2px solid var(--accent); box-shadow: 0 0 12px var(--accent); }
  .tl-item .when { font-family: var(--mono); font-size: var(--s--1); color: var(--accent); }
  .tl-item h3 { font-size: var(--s1); margin: .3rem 0; }
  .tl-item p { color: var(--muted); font-size: var(--s--1); }
</style>
