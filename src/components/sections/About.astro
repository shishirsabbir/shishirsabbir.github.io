---
import { profile, stats, about } from '~/data/profile';
const base = import.meta.env.BASE_URL;
---
<section id="about">
  <div class="container">
    <div class="about">
      <div class="about__photo reveal">
        <img src={`${base}headshot.png`} width="864" height="864" alt={`Portrait of ${profile.name}`} loading="lazy" decoding="async" />
      </div>
      <div>
        <p class="eyebrow reveal">01 — about</p>
        <h2 class="about__title reveal" data-d="1">Self-taught. Ship-focused.</h2>
        <p class="about__lead reveal" data-d="2">{about.lead}</p>
        <p class="about__body reveal" data-d="3">{about.body}</p>

        <div class="stats">
          {stats.map((s, i) => (
            <div class="stat reveal" data-d={String((i % 4) + 1)}>
              <div class="stat__num" data-count={s.value} data-suffix={s.suffix ?? ''}>0</div>
              <div class="stat__label">// {s.label}</div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .about { display: grid; grid-template-columns: .9fr 1.2fr; gap: var(--space-5); align-items: center; }
  @media (max-width: 820px) { .about { grid-template-columns: 1fr; } }

  .about__photo { position: relative; border-radius: var(--radius); padding: 6px; background: var(--grad); }
  .about__photo::before {
    content: ""; position: absolute; inset: -2px; border-radius: inherit; z-index: -1; filter: blur(8px);
    background: conic-gradient(from var(--ang), var(--accent), transparent 30%, var(--violet) 60%, transparent);
    animation: spin 6s linear infinite;
  }
  .about__photo img { border-radius: calc(var(--radius) - 4px); width: 100%; aspect-ratio: 1; object-fit: cover; }

  .about__title { font-size: var(--s2); margin-bottom: var(--space-3); }
  .about__lead, .about__body { color: var(--muted); font-size: var(--s1); margin-bottom: var(--space-3); }

  .stats { display: grid; grid-template-columns: repeat(2, 1fr); gap: 1px; margin-top: var(--space-4);
    background: var(--line); border: 1px solid var(--line); border-radius: var(--radius); overflow: hidden; }
  .stat { padding: var(--space-3); background: var(--bg-2); }
  .stat__num { font-family: var(--mono); font-size: var(--s2); font-weight: 700; color: var(--accent);
    text-shadow: 0 0 20px var(--accent-dim); font-variant-numeric: tabular-nums; }
  .stat__label { font-size: var(--s--1); color: var(--muted); }
</style>
